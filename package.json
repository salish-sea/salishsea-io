{
  "name": "salishsea-io",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^24.10"
  },
  "scripts": {
    "build": "tsc && vite build && npx html-validate dist/**/*.html && node bin/verify-csp-inline-hash.mjs dist/index.html",
    "build:size": "vite build",
    "dev": "vite dev",
    "gen-types": "supabase gen types --local --schema public --schema graphql_public > database.types.ts",
    "preview": "vite preview",
    "test": "vitest"
  },
  "dependencies": {
    "@formatjs/intl-datetimeformat": "^7.3.1",
    "@lit/context": "^1.1.6",
    "@lit/task": "1.0.3",
    "@sentry/browser": "^10.45.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@supabase/auth-js": "^2.99.3",
    "@supabase/sentry-js-integration": "^0.3.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/lit-form": "^1.23.25",
    "@turf/bearing": "^7.3.3",
    "@turf/distance": "^7.3.3",
    "@turf/helpers": "^7.2.0",
    "dompurify": "^3.3.3",
    "exifreader": "^4.37.0",
    "fast-xml-parser": "5.5.8",
    "geo-coordinates-parser": "^1.7.4",
    "lit": "^3.3.2",
    "marked": "17.0.4",
    "ol": "^10.7.0",
    "temporal-polyfill": "^0.3",
    "uuid": "^13.0.0",
    "vite": "^8.0.5",
    "zod": "^4.3.6"
  },
  "size-limit": [
    {
      "name": "JS",
      "path": "dist/assets/*.js"
    },
    {
      "name": "CSS",
      "path": "dist/assets/*.css"
    }
  ],
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.1",
    "@types/geojson": "^7946.0.16",
    "@types/google.accounts": "^0.0.18",
    "@types/jsdom": "^28.0.0",
    "html-validate": "^10.11.2",
    "jsdom": "^29.0.1",
    "size-limit": "^12.0.1",
    "supabase": "^2.82.0",
    "supertest": "^7.2.2",
    "type-fest": "^5.5.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  }
}

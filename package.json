{
  "name": "salishsea-io",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^24.10"
  },
  "scripts": {
    "build": "tsc && vite build && npx html-validate dist/**/*.html && node bin/verify-csp-inline-hash.mjs dist/index.html",
    "build:dwca": "tsx scripts/dwca/build.ts",
    "build:size": "vite build",
    "dev": "vite dev",
    "gen-types": "supabase gen types --local --schema public --schema graphql_public > database.types.ts",
    "preview": "vite preview",
    "test": "vitest"
  },
  "dependencies": {
    "@formatjs/intl-datetimeformat": "^7.4.9",
    "@lit/context": "^1.1.6",
    "@lit/task": "1.0.3",
    "@sentry/browser": "^10.59.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@supabase/auth-js": "^2.108.2",
    "@supabase/sentry-js-integration": "^0.3.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/lit-form": "^1.25.0",
    "@turf/bearing": "^7.3.5",
    "@turf/distance": "^7.3.5",
    "@turf/helpers": "^7.2.0",
    "dompurify": "^3.4.11",
    "exifreader": "^4.41.0",
    "fast-xml-parser": "5.9.3",
    "geo-coordinates-parser": "^1.7.4",
    "lit": "^3.3.3",
    "marked": "18.0.5",
    "ol": "^10.9.0",
    "temporal-polyfill": "^0.3",
    "uuid": "^14.0.1",
    "vite": "^8.0.16",
    "zod": "^4.3.6"
  },
  "size-limit": [
    {
      "name": "JS",
      "path": "dist/assets/*.js"
    },
    {
      "name": "CSS",
      "path": "dist/assets/*.css"
    }
  ],
  "devDependencies": {
    "@duckdb/node-api": "1.5.4-r.1",
    "@playwright/test": "^1.61.0",
    "@size-limit/file": "^12.1.0",
    "@types/geojson": "^7946.0.16",
    "@types/google.accounts": "^0.0.18",
    "@types/jsdom": "^28.0.3",
    "html-validate": "^11.5.3",
    "jsdom": "^29.0.2",
    "postgres": "^3.4.9",
    "size-limit": "^12.0.1",
    "supabase": "^2.107.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "type-fest": "^5.7.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9",
    "yazl": "3.3.1"
  }
}

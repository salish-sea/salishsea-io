# Beads kept local-only: issues live in the Dolt DB, not git.
# Auto-exported JSONL churns on every bd mutation, so it's not tracked.
# (git hooks disabled via: git config --unset core.hooksPath)
.beads/issues.jsonl
.beads/interactions.jsonl
